{
  "name": "ecommerce-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready e-commerce platform (Next.js + NestJS monorepo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean --force && rm -rf node_modules",
    "db:generate": "pnpm --filter api run db:generate",
    "db:migrate": "pnpm --filter api exec prisma migrate dev --schema=../../packages/database/prisma/schema.prisma",
    "db:studio": "pnpm --filter api exec prisma studio --schema=../../packages/database/prisma/schema.prisma",
    "db:seed": "pnpm --filter api run db:seed",
    "db:prepare": "pnpm db:generate && pnpm db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
