# ===========================================
# E-Commerce Platform - Environment template
# ===========================================
# Copy to .env and fill in values.
# For apps/web create apps/web/.env.local with NEXT_PUBLIC_* only if needed.

# --- API (apps/api) ---
NODE_ENV=development
PORT=4000
API_PREFIX=api

# PostgreSQL (required). Use same URL for migrations (run from root).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce

# Redis (optional for Day 1; required for cart/sessions later)
REDIS_URL=redis://localhost:6379

# JWT (change in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug

# --- Frontend (apps/web) - use .env.local in apps/web ---
# NEXT_PUBLIC_API_URL=http://localhost:4000/api

# --- Optional (Day 2+) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_IMAGES=
# CLOUDFRONT_URL=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@example.com
